-- ═══════════════════════════════════════════════════
local NotifHolder = create("Frame", {
    Name                   = genRandName(),
    BackgroundTransparency = 1,
    Position = UDim2.new(1, -245, 0, 8),
    Size     = UDim2.new(0, 235, 1, -16),
    ZIndex   = 200,
}, ScreenGui)
create("UIListLayout", {
    SortOrder         = Enum.SortOrder.LayoutOrder,
    Padding           = UDim.new(0, 3),
    VerticalAlignment = Enum.VerticalAlignment.Top,
}, NotifHolder)

local _nIdx = 0
local NOTIF_COL = {
    info    = Color3.fromRGB(84,101,255),
    success = Color3.fromRGB(50,190,100),
    warning = Color3.fromRGB(220,160,40),
    error   = Color3.fromRGB(220,50,50),
}
local NOTIF_ICON = { info="i", success="✓", warning="!", error="✕" }

-- [FIX 1] Verificamos Library.ShowNotifs al inicio de Notify.
-- Todos los callers (Elem.Toggle, Win:SaveConfig, etc.) pasan por aquí,
-- así que con un solo check centralizado queda resuelto para todos.
function Library:Notify(text, duration, ntype)
    if not Library.ShowNotifs then return end  -- << FIX 1

    duration = duration or 3
    ntype    = ntype or "info"
    local col  = NOTIF_COL[ntype]  or T.accent
    local icon = NOTIF_ICON[ntype] or "i"
    _nIdx += 1
    local wrap = create("Frame", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Size        = UDim2.new(1, 0, 0, 28),
        LayoutOrder = _nIdx,
    }, NotifHolder)
    local card = create("Frame", {
        Name             = genRandName(),
        BackgroundColor3 = T.bg1,
        BorderColor3     = T.border0,
        Size             = UDim2.new(1, 0, 1, 0),
        Position         = UDim2.new(1, 0, 0, 0),
        ZIndex           = 201,
    }, wrap)
    create("Frame", {
        Name             = genRandName(),
        BackgroundColor3 = col, BorderSizePixel = 0,
        Size = UDim2.new(0, 3, 1, 0), ZIndex = 202,
    }, card)
    create("TextLabel", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Position           = UDim2.new(0, 8, 0, 0),
        Size               = UDim2.new(0, 14, 1, 0),
        Font               = Enum.Font.Ubuntu,
        Text               = icon,
        TextColor3         = col,
        TextSize           = 11,
        TextXAlignment     = Enum.TextXAlignment.Center,
        ZIndex             = 202,
    }, card)
    create("TextLabel", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Position           = UDim2.new(0, 24, 0, 0),
        Size               = UDim2.new(1, -28, 1, 0),
        Font               = Enum.Font.Code,
        Text               = text,
        TextColor3         = T.txtNormal,
        TextSize           = 11,
        TextXAlignment     = Enum.TextXAlignment.Left,
        TextTruncate       = Enum.TextTruncate.AtEnd,
        ZIndex             = 202,
    }, card)
    local pbg = create("Frame", {
        Name             = genRandName(),
        BackgroundColor3 = T.border0, BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 1, -1), Size = UDim2.new(1, 0, 0, 1), ZIndex = 203,
    }, card)
    local pfg = create("Frame", {
        Name             = genRandName(),
        BackgroundColor3 = col, BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0), ZIndex = 204,
    }, pbg)
    tw(card, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 0, 0, 0)
    })
    task.spawn(function()
        task.wait(0.1)
        TweenServ:Create(pfg, TweenInfo.new(duration - 0.1, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 1, 0)
        }):Play()
    end)
    task.delay(duration, function()
        if not(card and card.Parent) then return end
        tw(card, TweenInfo.new(0.2, Enum.EasingStyle.Quad), { Position = UDim2.new(1, 0, 0, 0) })
        task.wait(0.25)
        if not(wrap and wrap.Parent) then return end
        tw(wrap, TweenInfo.new(0.12, Enum.EasingStyle.Quad), { Size = UDim2.new(1, 0, 0, 0) })
        task.wait(0.15)
        if wrap.Parent then wrap:Destroy() end
    end)
end

-- ═══════════════════════════════════════════════════
--  ELEMENT BUILDERS
-- ═══════════════════════════════════════════════════
local SLIDER_W = 260
local Elem = {}

-- ── TOGGLE ──────────────────────────────────────────
function Elem.Toggle(parent, bd, opts)
    opts = opts or {}
    local text     = opts.Text        or "Toggle"
    local def      = opts.Default     or false
    local desc     = opts.Description
    local callback = opts.Callback    or function() end
    local flag     = opts.Flag
    local h        = desc and 30 or 19

    bd.Size = bd.Size + UDim2.new(0, 0, 0, h)
    local st = def

    local Btn = create("TextButton", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Size             = UDim2.new(1, 0, 0, h),
        Text             = "",
        AutoButtonColor  = false,
    }, parent)

    local Bx = create("Frame", {
        Name             = genRandName(),
        AnchorPoint      = Vector2.new(0, 0.5),
        BackgroundColor3 = st and T.accent or T.bg2,
        BorderColor3     = st and T.accentDim or T.border0,
        Position         = UDim2.new(0, 8, desc and 0.35 or 0.5, 0),
        Size             = UDim2.new(0, 8, 0, 8),
    }, Btn)

    local Lb = create("TextLabel", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Position     = UDim2.new(0, 24, 0, 0),
        Size         = UDim2.new(0, 210, 0, desc and 17 or h),
        Font         = Enum.Font.Ubuntu,
        Text         = text,
        TextColor3   = st and T.txtBright or T.txtNormal,
        TextSize     = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, Btn)

    if desc then
        create("TextLabel", {
            Name                   = genRandName(),
            BackgroundTransparency = 1,
            Position     = UDim2.new(0, 24, 0, 16),
            Size         = UDim2.new(0, 210, 0, 12),
            Font         = Enum.Font.Ubuntu,
            Text         = desc,
            TextColor3   = T.txtDim,
            TextSize     = 10,
            TextXAlignment = Enum.TextXAlignment.Left,
        }, Btn)
    end

    local mi = false
    local function upd()
        tw(Bx, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
            BackgroundColor3 = st and T.accent    or T.bg2,
            BorderColor3     = st and T.accentDim or T.border0,
        })
        tw(Lb, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
            TextColor3 = st and T.txtBright or (mi and T.txtBright or T.txtNormal)
        })
    end

    Btn.MouseEnter:Connect(function()
        mi = true
        if not st then tw(Lb, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtBright}) end
    end)
    Btn.MouseLeave:Connect(function()
        mi = false
        if not st then tw(Lb, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtNormal}) end
    end)
    Btn.MouseButton1Down:Connect(function()
        st = not st; upd()
        callback(st)
        -- [FIX 1] Library:Notify ya verifica Library.ShowNotifs internamente,
        -- así que esta llamada es segura sin guardia adicional aquí.
        Library:Notify(text .. " " .. (st and "enabled" or "disabled"), 2, st and "success" or "warning")
    end)

    local obj = {
        Value  = st,
        Set    = function(self, v) st=v; self.Value=v; upd(); callback(v) end,
        Silent = function(self, v) st=v; self.Value=v; upd() end,
        Get    = function(self) return st end,
    }
    if flag then Library.Flags[flag] = obj end
    return obj
end

-- ── SLIDER ──────────────────────────────────────────
function Elem.Slider(parent, bd, opts)
    opts = opts or {}
    local text     = opts.Text     or "Slider"
    local mn       = opts.Min      or 0
    local mx       = opts.Max      or 100
    local def      = math.clamp(opts.Default or mn, mn, mx)
    local suffix   = opts.Suffix   or ""
    local decimals = opts.Decimals or 0
    local callback = opts.Callback or function() end
    local flag     = opts.Flag

    bd.Size = bd.Size + UDim2.new(0, 0, 0, 37)
    local val    = def
    local fmtStr = decimals > 0 and ("%." .. decimals .. "f") or "%d"

    local F = create("Frame", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 37),
    }, parent)

    local ST2 = create("TextLabel", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 5),
        Size     = UDim2.new(0, 170, 0, 13),
        Font     = Enum.Font.Ubuntu, Text = text,
        TextColor3 = T.txtNormal, TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, F)

    local SV = create("TextLabel", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 5),
        Size     = UDim2.new(0, SLIDER_W + 1, 0, 13),
        Font     = Enum.Font.Ubuntu,
        Text     = string.format(fmtStr, val) .. suffix,
        TextColor3 = T.txtNormal, TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Right,
    }, F)

    local SBt = create("TextButton", {
        Name             = genRandName(),
        BackgroundColor3 = T.bg2, BorderColor3 = T.border0,
        Position = UDim2.new(0, 8, 0, 21),
        Size     = UDim2.new(0, SLIDER_W, 0, 9),
        AutoButtonColor = false, Text = "",
    }, F)

    local px  = math.round((val - mn) / (mx - mn) * SLIDER_W)
    local SFl = create("Frame", {
        Name             = genRandName(),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BorderSizePixel  = 0,
        Size             = UDim2.new(0, px, 1, 0),
    }, SBt)
    create("UIGradient", {
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, T.accent),
            ColorSequenceKeypoint.new(1, T.accentDim),
        },
        Rotation = 90,
    }, SFl)
    local thumb = create("Frame", {
        Name             = genRandName(),
        Size             = UDim2.new(0, 7, 0, 9),
        Position         = UDim2.new(0, math.max(0, px - 3), 0, 0),
        BackgroundColor3 = T.txtBright,
        BorderSizePixel  = 0, ZIndex = 2,
    }, SBt)

    local sl, mi2 = false, false

    local function applyVal(raw)
        local rounded
        if decimals > 0 then
            local m = 10 ^ decimals
            rounded = math.floor(raw * m + 0.5) / m
        else
            rounded = math.floor(raw + 0.5)
        end
        val = math.clamp(rounded, mn, mx)
        local p2 = math.round((val - mn) / (mx - mn) * SLIDER_W)
        SFl.Size       = UDim2.new(0, p2, 1, 0)
        thumb.Position = UDim2.new(0, math.max(0, p2 - 3), 0, 0)
        SV.Text        = string.format(fmtStr, val) .. suffix
        callback(val)
    end

    local function fromMouse()
        local p   = math.clamp(mouse.X - SBt.AbsolutePosition.X, 0, SLIDER_W)
        local raw = mn + (mx - mn) * (p / SLIDER_W)
        applyVal(raw)
    end

    F.MouseEnter:Connect(function()
        mi2 = true
        tw(ST2, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtBright})
        tw(SV,  TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtBright})
    end)
    F.MouseLeave:Connect(function()
        mi2 = false
        if not sl then
            tw(ST2, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtNormal})
            tw(SV,  TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtNormal})
        end
    end)
    SBt.MouseButton1Down:Connect(function()
        sl = true; fromMouse()
        local mc = mouse.Move:Connect(fromMouse)
        local rc; rc = UIS.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                fromMouse(); sl = false
                if not mi2 then
                    tw(ST2, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtNormal})
                    tw(SV,  TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtNormal})
                end
                mc:Disconnect(); rc:Disconnect()
            end
        end)
    end)

    local obj = {
        Value  = val,
        Set    = function(self, v) applyVal(v); self.Value = val end,
        Silent = function(self, v)
            val = math.clamp(v, mn, mx)
            local p2 = math.round((val-mn)/(mx-mn)*SLIDER_W)
            SFl.Size = UDim2.new(0, p2, 1, 0)
            thumb.Position = UDim2.new(0, math.max(0, p2-3), 0, 0)
            SV.Text = string.format(fmtStr, val) .. suffix
            self.Value = val
        end,
        Get = function(self) return val end,
    }
    if flag then Library.Flags[flag] = obj end
    return obj
end

-- ── DROPDOWN ────────────────────────────────────────
function Elem.Dropdown(parent, bd, opts)
    opts = opts or {}
    local text     = opts.Text     or "Dropdown"
    local list     = opts.List     or {}
    local def      = opts.Default  or list[1]
    local callback = opts.Callback or function() end
    local flag     = opts.Flag

    bd.Size = bd.Size + UDim2.new(0, 0, 0, 46)
    local sel = def

    local W2 = create("Frame", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 46),
    }, parent)

    local DT = create("TextLabel", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 5),  Size = UDim2.new(0, 200, 0, 13),
        Font = Enum.Font.Ubuntu, Text = text,
        TextColor3 = T.txtNormal, TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, W2)

    local DB = create("TextButton", {
        Name             = genRandName(),
        BackgroundColor3 = T.bg2, BorderColor3 = T.border0,
        Position = UDim2.new(0, 8, 0, 21), Size = UDim2.new(0, 260, 0, 19),
        AutoButtonColor = false, Text = "",
    }, W2)

    local DBT = create("TextLabel", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 6, 0, 0), Size = UDim2.new(0, 240, 1, 0),
        Font = Enum.Font.Ubuntu, Text = tostring(sel or ""),
        TextColor3 = T.txtNormal, TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, DB)
    create("ImageLabel", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 245, 0, 8), Size = UDim2.new(0, 6, 0, 4),
        Image = "rbxassetid://6724771531", ImageColor3 = T.txtNormal,
    }, DB)

    local sH = #list >= 4 and 76 or (19 * #list)
    local DS = create("ScrollingFrame", {
        Name             = genRandName(),
        Active = true, BackgroundColor3 = T.bg2, BorderColor3 = T.border0,
        Size = UDim2.new(0, 260, 0, sH),
        CanvasSize = UDim2.new(0, 0, 0, 19 * #list),
        ScrollBarThickness = 2, ScrollBarImageColor3 = T.accentDim,
        Visible = false, ZIndex = 50,
        TopImage    = "rbxasset://textures/ui/Scroll/scroll-middle.png",
        BottomImage = "rbxasset://textures/ui/Scroll/scroll-middle.png",
    }, ScreenGui)
    create("UIListLayout", {
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        SortOrder = Enum.SortOrder.LayoutOrder,
    }, DS)

    local iD, iS = false, false

    local function openDD()
        local bp = DB.AbsolutePosition
        DS.Position = UDim2.new(0, bp.X, 0, bp.Y + DB.AbsoluteSize.Y + 2)
        DS.Visible  = true
        tw(DT,  TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtBright})
        tw(DBT, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtBright})
    end
    local function closeDD()
        DS.Visible = false; DS.CanvasPosition = Vector2.new(0,0)
        tw(DT,  TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtNormal})
        tw(DBT, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtNormal})
    end

    DB.MouseButton1Down:Connect(function()
        if DS.Visible then closeDD() else openDD() end
    end)
    W2.MouseEnter:Connect(function() iD = true end)
    W2.MouseLeave:Connect(function() iD = false end)
    DS.MouseEnter:Connect(function() iS = true end)
    DS.MouseLeave:Connect(function() iS = false end)
    hook(UIS.InputBegan, function(inp)
        if (inp.UserInputType == Enum.UserInputType.MouseButton1 or
            inp.UserInputType == Enum.UserInputType.MouseButton2)
            and DS.Visible and not iD and not iS then
            closeDD()
        end
    end)

    local function buildItems()
        for _, ch in ipairs(DS:GetChildren()) do
            if not ch:IsA("UIListLayout") then ch:Destroy() end
        end
        for _, opt in ipairs(list) do
            local OB = create("TextButton", {
                Name             = genRandName(),
                BackgroundColor3 = T.bg2, BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 19),
                AutoButtonColor = false, Text = "", ZIndex = 50,
            }, DS)
            local OT = create("TextLabel", {
                Name                   = genRandName(),
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 7, 0, 0), Size = UDim2.new(0, 246, 1, 0),
                Font = Enum.Font.Ubuntu, Text = tostring(opt),
                TextColor3 = T.txtNormal, TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 50,
            }, OB)
            local OD = create("Frame", {
                Name             = genRandName(),
                BackgroundColor3 = T.accent, BorderSizePixel = 0,
                Size = UDim2.new(0, 2, 1, 0), Visible = false, ZIndex = 50,
            }, OB)
            OB.MouseEnter:Connect(function()
                tw(OT, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {TextColor3=T.txtBright})
                OD.Visible = true
            end)
            OB.MouseLeave:Connect(function()
                tw(OT, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {TextColor3=T.txtNormal})
                OD.Visible = false
            end)
            OB.MouseButton1Down:Connect(function()
                sel = opt; DBT.Text = tostring(opt); closeDD(); callback(opt)
            end)
        end
    end
    buildItems()

    local obj = {
        Value   = sel,
        Set     = function(self, v) sel=v; self.Value=v; DBT.Text=tostring(v); callback(v) end,
        Silent  = function(self, v) sel=v; self.Value=v; DBT.Text=tostring(v) end,
        Refresh = function(self, newList)
            list = newList
            sel  = newList[1]
            self.Value  = sel
            DBT.Text    = tostring(sel or "")
            sH = #newList >= 4 and 76 or (19 * #newList)
            DS.Size       = UDim2.new(0, 260, 0, sH)
            DS.CanvasSize = UDim2.new(0, 0, 0, 19 * #newList)
            buildItems()
        end,
        Get = function(self) return sel end,
    }
    if flag then Library.Flags[flag] = obj end
    return obj
end

-- ── KEYBIND ─────────────────────────────────────────
function Elem.Keybind(parent, bd, opts)
    opts = opts or {}
    local text     = opts.Text     or "Keybind"
    local def      = opts.Default
    local callback = opts.Callback or function() end
    local flag     = opts.Flag

    bd.Size = bd.Size + UDim2.new(0, 0, 0, 19)
    local key     = def
    local binding = false

    local Btn = create("TextButton", {
        Name                   = genRandName(),
        BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 19),
        Text = "", AutoButtonColor = false,
    }, parent)

    local Lb = create("TextLabel", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 0), Size = UDim2.new(0, 160, 1, 0),
        Font = Enum.Font.Ubuntu, Text = text,
        TextColor3 = T.txtNormal, TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, Btn)

    local KL = create("TextButton", {
        Name             = genRandName(),
        AnchorPoint = Vector2.new(1, 0),
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 265, 0, 0), Size = UDim2.new(0, 90, 0, 19),
        Font = Enum.Font.Ubuntu,
        Text = "[" .. (key and key.Name or "none") .. "]",
        TextColor3 = T.txtNormal, TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Right,
        AutoButtonColor = false,
    }, Btn)

    Btn.MouseEnter:Connect(function()
        tw(Lb, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtBright})
        tw(KL, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtBright})
    end)
    Btn.MouseLeave:Connect(function()
        tw(Lb, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtNormal})
        tw(KL, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtNormal})
    end)
    KL.MouseButton1Down:Connect(function()
        if binding then return end
        binding = true
        Library._bindingKey = true  -- [FIX 2] Bloquea el toggle del menú
        KL.Text = "[...]"
        tw(KL, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {TextColor3=T.txtAccent})
        local cn; cn = hook(UIS.InputBegan, function(inp)
            if inp.UserInputType == Enum.UserInputType.Keyboard then
                binding = false
                Library._bindingKey = false  -- [FIX 2] Desbloquea el toggle del menú
                if inp.KeyCode == Enum.KeyCode.Escape or inp.KeyCode == Enum.KeyCode.Backspace then
                    key = nil; KL.Text = "[none]"
                else
                    key = inp.KeyCode; KL.Text = "[" .. key.Name .. "]"
                end
                tw(KL, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {TextColor3=T.txtNormal})
                callback(key); cn:Disconnect()
            end
        end)
    end)

    local obj = {
        Value  = key,
        Set    = function(self, v) key=v; self.Value=v; KL.Text="["..(key and key.Name or "none").."]"; callback(v) end,
        Silent = function(self, v) key=v; self.Value=v; KL.Text="["..(key and key.Name or "none").."]" end,
        Get    = function(self) return key end,
    }
    if flag then Library.Flags[flag] = obj end
    return obj
end

-- ── COLOR PICKER (CON LIVE PREVIEW) ─────────────────
function Elem.ColorPicker(parent, bd, opts)
    opts = opts or {}
    local text        = opts.Text        or "Color"
    local def         = opts.Default     or Color3.new(1,1,1)
    local callback    = opts.Callback    or function() end
    local flag        = opts.Flag
    local previewType = opts.PreviewType

    bd.Size = bd.Size + UDim2.new(0, 0, 0, 19)
    local color     = def
    local ch, cs, cv = Color3.toHSV(color)

    local Row = create("TextButton", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 19),
        Text = "",
        AutoButtonColor = false,
    }, parent)

    local CL = create("TextLabel", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 0),
        Size     = UDim2.new(0, 200, 1, 0),
        Font     = Enum.Font.Ubuntu,
        Text     = text,
        TextColor3 = T.txtNormal,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, Row)

    local CB = create("TextButton", {
        Name             = genRandName(),
        AnchorPoint = Vector2.new(1, 0.5),
        BackgroundColor3 = color,
        BorderColor3     = T.border1,
        Position = UDim2.new(0, 267, 0.5, 0),
        Size     = UDim2.new(0, 32, 0, 10),
        AutoButtonColor = false,
        Text = "",
    }, Row)

    Row.MouseEnter:Connect(function()
        tw(CL, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtBright})
    end)
    Row.MouseLeave:Connect(function()
        tw(CL, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {TextColor3=T.txtNormal})
    end)

    local CF = create("Frame", {
        Name             = genRandName(),
        BackgroundColor3 = T.bg1,
        BorderColor3     = T.border1,
        Size = UDim2.new(0, 200, 0, 172),
        Visible = false,
        ZIndex = 100,
    }, ScreenGui)
    setDraggable(CF)

    local HB = create("TextButton", {
        Name             = genRandName(),
        BackgroundColor3 = Color3.new(1,1,1),
        BorderColor3     = T.border0,
        Position = UDim2.new(0, 10, 0, 10),
        Size     = UDim2.new(0, 20, 0, 150),
        AutoButtonColor = false,
        Text = "",
        ZIndex = 101,
    }, CF)
    create("UIGradient", {
        Rotation = 90,
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0,    Color3.fromRGB(255,0,0)),
            ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255,255,0)),
            ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0,255,0)),
            ColorSequenceKeypoint.new(0.5,  Color3.fromRGB(0,255,255)),
            ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0,0,255)),
            ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255,0,255)),
            ColorSequenceKeypoint.new(1,    Color3.fromRGB(255,0,0)),
        },
    }, HB)

    local HP = create("Frame", {
        Name             = genRandName(),
        BackgroundColor3 = Color3.new(1,1,1),
        BorderColor3     = Color3.new(0,0,0),
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, ch, -1),
        ZIndex = 102,
    }, HB)

    local CM = create("TextButton", {
        Name             = genRandName(),
        BackgroundColor3 = Color3.fromHSV(ch,1,1),
        BorderColor3     = T.border0,
        Position = UDim2.new(0, 40, 0, 10),
        Size     = UDim2.new(0, 150, 0, 150),
        AutoButtonColor = false,
        Text = "",
        ZIndex = 101,
    }, CF)

    local SO = create("Frame", {
        Name             = genRandName(),
        BackgroundColor3 = Color3.new(1,1,1),
        BorderSizePixel  = 0,
        Size = UDim2.new(1,0,1,0),
        ZIndex = 102,
    }, CM)
    create("UIGradient", {
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
            ColorSequenceKeypoint.new(1, Color3.new(1,1,1)),
        },
        Transparency = NumberSequence.new{
            NumberSequenceKeypoint.new(0,0),
            NumberSequenceKeypoint.new(1,1),
        },
    }, SO)

    local VO = create("Frame", {
        Name             = genRandName(),
        BackgroundColor3 = Color3.new(0,0,0),
        BorderSizePixel  = 0,
        Size = UDim2.new(1,0,1,0),
        ZIndex = 103,
    }, CM)
    create("UIGradient", {
        Rotation = 90,
        Transparency = NumberSequence.new{
            NumberSequenceKeypoint.new(0,1),
            NumberSequenceKeypoint.new(1,0),
        },
    }, VO)

    local CP = create("Frame", {
        Name             = genRandName(),
        BackgroundColor3 = Color3.new(1,1,1),
        BorderColor3     = Color3.new(0,0,0),
        Size = UDim2.new(0,3,0,3),
        Position = UDim2.new(cs,-1,1-cv,-1),
        ZIndex = 104,
    }, CM)

    local CMH = create("TextButton", {
        Name                   = genRandName(),
        BackgroundTransparency = 1,
        Size = UDim2.new(1,0,1,0),
        Text = "",
        ZIndex = 105,
        AutoButtonColor = false,
    }, CM)

    local function updP()
        color = Color3.fromHSV(ch, cs, cv)
        CB.BackgroundColor3 = color
        CM.BackgroundColor3 = Color3.fromHSV(ch, 1, 1)
        CP.Position = UDim2.new(cs, -1, 1-cv, -1)
        HP.Position = UDim2.new(0, 0, ch, -1)
        if previewType == "fov" and LivePreviews.FOVCircle then
            LivePreviews.FOVCircle.Color = color
        elseif previewType == "esp_visible" and LivePreviews.ESPBox then
            LivePreviews.ESPBox.Color = color
        elseif previewType == "esp_hidden" and LivePreviews.ESPBox then
            LivePreviews.ESPBox.Color = color
        end
        callback(color)
    end

    CMH.MouseButton1Down:Connect(function()
        local function u()
            cs = math.clamp(mouse.X-CM.AbsolutePosition.X,0,CM.AbsoluteSize.X)/CM.AbsoluteSize.X
            cv = 1 - math.clamp(mouse.Y-CM.AbsolutePosition.Y,0,CM.AbsoluteSize.Y)/CM.AbsoluteSize.Y
            updP()
        end
        u()
        local mc = mouse.Move:Connect(u)
        local rc; rc = UIS.InputEnded:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then
                u(); mc:Disconnect(); rc:Disconnect()
            end
        end)
    end)

    HB.MouseButton1Down:Connect(function()
        local function u()
            local y = math.clamp(mouse.Y-HB.AbsolutePosition.Y,0,HB.AbsoluteSize.Y)
            ch = y/HB.AbsoluteSize.Y
            updP()
        end
        u()
        local mc = mouse.Move:Connect(u)
        local rc; rc = UIS.InputEnded:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then
                u(); mc:Disconnect(); rc:Disconnect()
            end
        end)
    end)

    local iCF, iCB2 = false, false
    CB.MouseButton1Down:Connect(function()
        if CF.Visible then
            CF.Visible=false
            if previewType == "fov" and LivePreviews.FOVCircle then
                LivePreviews.FOVCircle.Visible = false
            elseif (previewType == "esp_visible" or previewType == "esp_hidden") and LivePreviews.ESPBox then
                LivePreviews.ESPBox.Visible = false
            end
            return
        end
        local bp = CB.AbsolutePosition
        CF.Position = UDim2.new(0, bp.X+CB.AbsoluteSize.X+6, 0, bp.Y-10)
        CF.Visible = true
        if previewType == "fov" and LivePreviews.FOVCircle then
            LivePreviews.FOVCircle.Visible = true
            LivePreviews.FOVCircle.Color = color
        elseif (previewType == "esp_visible" or previewType == "esp_hidden") and LivePreviews.ESPBox then
            LivePreviews.ESPBox.Visible = true
            LivePreviews.ESPBox.Color = color
        end
    end)

    CF.MouseEnter:Connect(function() iCF=true end)
    CF.MouseLeave:Connect(function() iCF=false end)
    CB.MouseEnter:Connect(function() iCB2=true end)
    CB.MouseLeave:Connect(function() iCB2=false end)

    hook(UIS.InputBegan, function(inp)
        if (inp.UserInputType==Enum.UserInputType.MouseButton1 or
            inp.UserInputType==Enum.UserInputType.MouseButton2)
            and CF.Visible and not iCF and not iCB2 then
            CF.Visible = false
            if previewType == "fov" and LivePreviews.FOVCircle then
                LivePreviews.FOVCircle.Visible = false
            elseif (previewType == "esp_visible" or previewType == "esp_hidden") and LivePreviews.ESPBox then
                LivePreviews.ESPBox.Visible = false
            end
        end
    end)

    local obj = {
        Value  = color,
        Set    = function(self, cl)
            color=cl; ch,cs,cv=Color3.toHSV(cl); self.Value=cl; updP()
        end,
        Silent = function(self, cl)
            color=cl; ch,cs,cv=Color3.toHSV(cl); self.Value=cl
            CB.BackgroundColor3=color; CM.BackgroundColor3=Color3.fromHSV(ch,1,1)
            CP.Position=UDim2.new(cs,-1,1-cv,-1); HP.Position=UDim2.new(0,0,ch,-1)
            if previewType == "fov" and LivePreviews.FOVCircle then
                LivePreviews.FOVCircle.Color = color
            elseif (previewType == "esp_visible" or previewType == "esp_hidden") and LivePreviews.ESPBox then
                LivePreviews.ESPBox.Color = color
            end
        end,
        Get = function(self) return color end,
    }
    if flag then Library.Flags[flag] = obj end
    return obj
end

-- ── BUTTON ──────────────────────────────────────────
function Elem.Button(parent, bd, opts)
    opts = opts or {}
    local text     = opts.Text     or "Button"
    local style    = opts.Style    or "default"
    local callback = opts.Callback or function() end

    local bgMap = {
        default = {T.bg2,    T.bg3,                           T.accent},
        accent  = {T.accentDim, T.accent,                     T.accent},
        danger  = {Color3.fromRGB(90,22,22), Color3.fromRGB(130,32,32), T.red},
        success = {Color3.fromRGB(20,68,40), Color3.fromRGB(28,90,52),  T.green},
    }
    local c = bgMap[style] or bgMap.default

    bd.Size = bd.Size + UDim2.new(0, 0, 0, 28)
    local BF = create("Frame", {Name=genRandName(),BackgroundTransparency=1, Size=UDim2.new(1,0,0,28)}, parent)
    local B  = create("TextButton", {
        Name             = genRandName(),
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundColor3 = c[1], BorderColor3 = T.border0,
        Position = UDim2.new(0.5,0,0.5,0), Size = UDim2.new(0,215,0,18),
        AutoButtonColor = false, Font = Enum.Font.Ubuntu,
        Text = text, TextColor3 = T.txtNormal, TextSize = 13,
    }, BF)
    B.MouseEnter:Connect(function()
        tw(B, TweenInfo.new(0.12,Enum.EasingStyle.Quad), {BackgroundColor3=c[2], TextColor3=T.txtBright})
    end)
    B.MouseLeave:Connect(function()
        tw(B, TweenInfo.new(0.12,Enum.EasingStyle.Quad), {BackgroundColor3=c[1], TextColor3=T.txtNormal})
    end)
    B.MouseButton1Down:Connect(function()
        B.BorderColor3 = c[3]
        tw(B, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BorderColor3=T.border0})
        callback()
    end)
end

-- ── LABEL ───────────────────────────────────────────
function Elem.Label(parent, bd, text, subtext)
    local h = subtext and 28 or 16
    bd.Size = bd.Size + UDim2.new(0, 0, 0, h)
    local F = create("Frame", {Name=genRandName(),BackgroundTransparency=1, Size=UDim2.new(1,0,0,h)}, parent)
    create("TextLabel", {
        Name=genRandName(),
        BackgroundTransparency=1, Size=UDim2.new(1,0,0,16),
        Font=Enum.Font.Ubuntu, Text="  "..text,
        TextColor3=T.txtNormal, TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left,
    }, F)
    if subtext then
        create("TextLabel", {
            Name=genRandName(),
            BackgroundTransparency=1, Position=UDim2.new(0,0,0,16),
            Size=UDim2.new(1,0,0,12),
            Font=Enum.Font.Ubuntu, Text="  "..subtext,
            TextColor3=T.txtDim, TextSize=10,
            TextXAlignment=Enum.TextXAlignment.Left,
        }, F)
    end
end

-- ── TEXT BOX ────────────────────────────────────────
function Elem.TextBox(parent, bd, opts)
    opts = opts or {}
    local ph         = opts.Placeholder  or "type here..."
    local def        = opts.Default      or ""
    local numeric    = opts.Numeric      or false
    local clearFocus = opts.ClearOnFocus ~= false
    local callback   = opts.Callback     or function() end
    local flag       = opts.Flag

    bd.Size = bd.Size + UDim2.new(0, 0, 0, 28)
    local BF = create("Frame", {Name=genRandName(),BackgroundTransparency=1, Size=UDim2.new(1,0,0,28)}, parent)
    local TB = create("TextBox", {
        Name=genRandName(),
        AnchorPoint = Vector2.new(0.5,0.5),
        BackgroundColor3 = T.bg2, BorderColor3 = T.border0,
        Position = UDim2.new(0.5,0,0.5,0), Size = UDim2.new(0,215,0,18),
        Font = Enum.Font.Ubuntu, Text = def,
        PlaceholderText = ph, PlaceholderColor3 = T.txtDim,
        TextColor3 = T.txtNormal, TextSize = 13,
        ClearTextOnFocus = clearFocus,
    }, BF)
    TB.Focused:Connect(function()
        tw(TB, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {BorderColor3=T.accent})
    end)
    TB.FocusLost:Connect(function(enter)
        tw(TB, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {BorderColor3=T.border0})
        callback(TB.Text, enter)
    end)
    if numeric then
        TB:GetPropertyChangedSignal("Text"):Connect(function()
            TB.Text = TB.Text:gsub("[^%d%.%-]", "")
        end)
    end

    local obj = {
        Value = TB.Text,
        Set   = function(self, v) TB.Text=tostring(v); self.Value=TB.Text end,
        Get   = function(self) return TB.Text end,
    }
    if flag then Library.Flags[flag] = obj end
    return obj
end

-- ── SEPARATOR ───────────────────────────────────────
function Elem.Separator(parent, bd)
    bd.Size = bd.Size + UDim2.new(0, 0, 0, 12)
    local F = create("Frame", {Name=genRandName(),BackgroundTransparency=1, Size=UDim2.new(1,0,0,12)}, parent)
    create("Frame", {
        Name=genRandName(),
        BackgroundColor3 = T.border1, BorderSizePixel = 0,
        Position = UDim2.new(0,8,0.5,-1), Size = UDim2.new(1,-16,0,1),
    }, F)
end

-- ── PARAGRAPH ───────────────────────────────────────
function Elem.Paragraph(parent, bd, opts)
    opts = opts or {}
    local title   = opts.Title   or ""
    local content = opts.Content or ""
    local lines   = math.max(1, math.ceil(#content / 40))
    local h       = (title~="" and 14 or 0) + lines * 13 + 12

    bd.Size = bd.Size + UDim2.new(0, 0, 0, h)
    local F = create("Frame", {
        Name=genRandName(),
        BackgroundColor3 = T.bg2, BorderColor3 = T.border0,
        Size = UDim2.new(1,-16,0,h),
    }, parent)

    local titleLbl
    if title ~= "" then
        titleLbl = create("TextLabel", {
            Name=genRandName(),
            BackgroundTransparency = 1,
            Position = UDim2.new(0,7,0,4), Size = UDim2.new(1,-14,0,12),
            Font = Enum.Font.Ubuntu, Text = title,
            TextColor3 = T.txtAccent, TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
        }, F)
    end

    local contentLbl = create("TextLabel", {
        Name=genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0,7,0, title~="" and 17 or 5),
        Size     = UDim2.new(1,-14,0, h-(title~="" and 20 or 8)),
        Font     = Enum.Font.Ubuntu, Text = content,
        TextColor3 = T.txtDim, TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
    }, F)

    return {
        SetTitle   = function(_, v) if titleLbl then titleLbl.Text = v end end,
        SetContent = function(_, v) contentLbl.Text = v end,
    }
end

-- ═══════════════════════════════════════════════════
--  SECTOR
-- ═══════════════════════════════════════════════════
local function makeSector(scrollParent, name, lo)
    local Bd = create("Frame", {
        Name=genRandName(),
        BackgroundColor3 = T.border1, BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 22), LayoutOrder = lo or 0,
    }, scrollParent)
    local Ct = create("Frame", {
        Name=genRandName(),
        BackgroundColor3 = T.bg1, BorderSizePixel = 0,
        Position = UDim2.new(0,1,0,1), Size = UDim2.new(1,-2,1,-2),
    }, Bd)
    create("UIListLayout", {
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        SortOrder = Enum.SortOrder.LayoutOrder,
    }, Ct)
    create("UIPadding", {PaddingTop = UDim.new(0,11)}, Ct)
    create("TextLabel", {
        Name=genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0,7,0,-8), Size = UDim2.new(1,-7,0,14),
        Font = Enum.Font.Ubuntu, Text = "// " .. name,
        TextColor3 = T.txtNormal, TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, Bd)

    local S = {}
    function S:AddToggle(o)       return Elem.Toggle(Ct, Bd, o) end
    function S:AddSlider(o)       return Elem.Slider(Ct, Bd, o) end
    function S:AddDropdown(o)     return Elem.Dropdown(Ct, Bd, o) end
    function S:AddKeybind(o)      return Elem.Keybind(Ct, Bd, o) end
    function S:AddColorPicker(o)  return Elem.ColorPicker(Ct, Bd, o) end
    function S:AddButton(o)       return Elem.Button(Ct, Bd, o) end
    function S:AddLabel(t, s)     return Elem.Label(Ct, Bd, t, s) end
    function S:AddTextBox(o)      return Elem.TextBox(Ct, Bd, o) end
    function S:AddSeparator()     return Elem.Separator(Ct, Bd) end
    function S:AddParagraph(o)    return Elem.Paragraph(Ct, Bd, o) end
    return S
end

-- ═══════════════════════════════════════════════════
--  COLUMN
-- ═══════════════════════════════════════════════════
local function makeColumn(parent, xOffset)
    local scroll = create("ScrollingFrame", {
        Name=genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0, xOffset, 0, 6),
        Size     = UDim2.new(0, 284, 1, -10),
        CanvasSize          = UDim2.new(0,0,0,0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollBarThickness  = 2,
        ScrollBarImageColor3 = T.accentDim,
        BorderSizePixel     = 0,
        TopImage    = "rbxasset://textures/ui/Scroll/scroll-middle.png",
        BottomImage = "rbxasset://textures/ui/Scroll/scroll-middle.png",
    }, parent)
    create("UIListLayout", {
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding   = UDim.new(0, 14),
    }, scroll)
    create("UIPadding", {PaddingTop = UDim.new(0,12)}, scroll)

    local sc = 0
    local Col = {}
    function Col:AddSector(name)
        sc += 1
        return makeSector(scroll, name, sc)
    end
    return Col
end

-- ═══════════════════════════════════════════════════
--  CONFIG SYSTEM
-- ═══════════════════════════════════════════════════
local CFG_FOLDER   = "AnnomalyUILib"
local CFG_AUTONAME = "__autoload"

local function cfgInit()
    if not isfolder then return false end
    if not isfolder(CFG_FOLDER) then pcall(makefolder, CFG_FOLDER) end
    return isfolder(CFG_FOLDER)
end
local function cfgPath(n) return CFG_FOLDER .. "/" .. n .. ".json" end

local function cfgSave(name, data)
    if not cfgInit() then return false end
    local ok, j = pcall(function() return HttpService:JSONEncode(data) end)
    if not ok then return false end
    return pcall(writefile, cfgPath(name), j)
end
local function cfgLoad(name)
    if not cfgInit() then return nil end
    local p = cfgPath(name); if not isfile(p) then return nil end
    local ok, j = pcall(readfile, p); if not ok then return nil end
    local ok2, d = pcall(function() return HttpService:JSONDecode(j) end)
    return ok2 and d or nil
end
local function cfgDel(name)
    if not cfgInit() then return end
    local p = cfgPath(name); if isfile(p) then pcall(delfile, p) end
end
local function cfgList()
    if not cfgInit() then return {} end
    local out = {}
    pcall(function()
        for _, f in ipairs(listfiles(CFG_FOLDER)) do
            local n = f:match("([^/\\]+)%.json$")
            if n and n ~= CFG_AUTONAME then out[#out+1] = n end
        end
    end)
    return out
end
local function cfgSetAuto(name)
    if cfgInit() then
        pcall(writefile, cfgPath(CFG_AUTONAME), HttpService:JSONEncode({a=name}))
    end
end
local function cfgGetAuto()
    if not cfgInit() then return nil end
    local p = cfgPath(CFG_AUTONAME); if not isfile(p) then return nil end
    local ok, j = pcall(readfile, p); if not ok then return nil end
    local ok2, d = pcall(function() return HttpService:JSONDecode(j) end)
    return ok2 and d.a or nil
end
local function cfgClearAuto()
    if not cfgInit() then return end
    local p = cfgPath(CFG_AUTONAME); if isfile(p) then pcall(delfile, p) end
end

-- ═══════════════════════════════════════════════════
--  CREATE WINDOW
-- ═══════════════════════════════════════════════════
function Library:CreateWindow(opts)
    opts = opts or {}

    local Win = {}

    Win.Title      = opts.Title      or "annomalyui"
    Win.Subtitle   = opts.Subtitle   or "universal"
    Win.Version    = opts.Version    or "1.0"
    Win.ToggleKey  = opts.ToggleKey  or Enum.KeyCode.End
    Win.ShowNotifs = opts.Notifications ~= false

    -- [FIX 1] Sincronizamos el flag global con la opción de esta ventana.
    -- Library:Notify lo leerá antes de mostrar cualquier notificación.
    Library.ShowNotifs = Win.ShowNotifs

    local Main = create("ImageButton", {
        Name             = LEGIT_FRAME_NAMES[math.random(1, #LEGIT_FRAME_NAMES)],
        AnchorPoint      = Vector2.new(0.5, 0.5),
        BackgroundColor3 = T.bg0,
        BorderColor3     = T.accent,
        Position         = UDim2.new(0.5, 0, 0.5, 0),
        Size             = UDim2.new(0, 700, 0, 500),
        AutoButtonColor  = false,
        Modal            = false,
        Image            = "",
    }, ScreenGui)
    setDraggable(Main)

    create("ImageLabel", {
        Name=genRandName(),
        BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0),
        Image = "http://www.roblox.com/asset/?id=7300333488",
        ImageTransparency = 0.97,
        ScaleType = Enum.ScaleType.Tile, TileSize = UDim2.new(0,128,0,128),
        ZIndex = 0,
    }, Main)
    create("Frame", {
        Name=genRandName(),
        BackgroundColor3 = T.accent, BorderSizePixel = 0,
        Size = UDim2.new(1,0,0,1), ZIndex = 3,
    }, Main)

    local titleTag = Win.Subtitle ~= "" and Win.Subtitle:lower() or "ui"
    create("TextLabel", {
        Name=genRandName(),
        AnchorPoint = Vector2.new(0.5, 0),
        BackgroundTransparency = 1,
        Position = UDim2.new(0.5,0,0,1), Size = UDim2.new(1,-22,0,29),
        Font = Enum.Font.Ubuntu,
        Text = '<font color="rgb(84,101,255)">'..Win.Title:lower()..'</font>'..
               '<font color="rgb(35,35,35)"> //</font>'..
               '<font color="rgb(90,90,90)"> '..titleTag..'</font>'..
               '<font color="rgb(35,35,35)">  v'..Win.Version..'</font>',
        TextColor3 = T.txtBright, TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        RichText = true, ZIndex = 2,
    }, Main)
    create("Frame", {
        Name=genRandName(),
        BackgroundColor3 = T.border0, BorderSizePixel = 0,
        Position = UDim2.new(0,0,0,30), Size = UDim2.new(1,0,0,1), ZIndex = 2,
    }, Main)
    create("Frame", {
        Name=genRandName(),
        BackgroundColor3 = T.border0, BorderSizePixel = 0,
        Position = UDim2.new(0,96,0,31), Size = UDim2.new(0,1,0,451), ZIndex = 2,
    }, Main)

    local FooterBar = create("Frame", {
        Name=genRandName(),
        BackgroundColor3 = T.bg1, BorderColor3 = T.border0,
        Position = UDim2.new(0,0,1,-17), Size = UDim2.new(1,0,0,17), ZIndex = 2,
    }, Main)
    create("Frame", {
        Name=genRandName(),
        BackgroundColor3 = T.border0, BorderSizePixel = 0,
        Size = UDim2.new(1,0,0,1), ZIndex = 3,
    }, FooterBar)
    local FooterText = create("TextLabel", {
        Name=genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0,8,0,0), Size = UDim2.new(1,-16,1,0),
        Font = Enum.Font.Ubuntu, Text = "> idle",
        TextColor3 = T.txtNormal, TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 3,
    }, FooterBar)

    local TabButtons = create("Frame", {
        Name=genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0,0,0,31), Size = UDim2.new(0,97,0,452),
    }, Main)
    create("UIListLayout", {HorizontalAlignment = Enum.HorizontalAlignment.Center}, TabButtons)

    local TabsFrame = create("Frame", {
        Name=genRandName(),
        BackgroundTransparency = 1,
        Position = UDim2.new(0,100,0,31), Size = UDim2.new(0,586,0,452),
    }, Main)

    -- [FIX 2] El hook del toggle ahora verifica Library._bindingKey.
    -- Si un Keybind está esperando input, este hook no actúa, evitando
    -- que la tecla nueva también dispare accidentalmente el toggle.
hook(UIS.InputBegan, function(key)
    if UIS:GetFocusedTextBox() then return end
    if Library._bindingKey then return end
    if key.KeyCode == Win.ToggleKey then
        Main.Visible = not Main.Visible
        setCursorVisible(Main.Visible)
        if Main.Visible then
            UIS.MouseBehavior = Enum.MouseBehavior.Default
        end
        -- Cuando se cierra, NO forzar nada, el juego recupera el control solo
    end
end)

hook(RunService.RenderStepped, function()
    if Main and Main.Visible then
        UIS.MouseIconEnabled = false
        setCursorVisible(true)
        -- Solo cambiar MouseBehavior cuando el menú ESTÁ abierto
        -- y solo si no estamos en un TextBox
        if not UIS:GetFocusedTextBox() then
            UIS.MouseBehavior = Enum.MouseBehavior.Default
        end
    else
        setCursorVisible(false)
        UIS.MouseIconEnabled = true
        -- NO tocar MouseBehavior aquí, dejar que el juego lo controle
    end
end)

    local _footerParts    = {}
    local _firstTab       = true
    local _selectedTabBtn = nil

    task.spawn(function()
        while task.wait(0.5) do
            if not(Main and Main.Parent) then break end
            local status = #_footerParts > 0
                and table.concat(_footerParts, " | ")
                or "idle"
            FooterText.Text       = "> [" .. Win.ToggleKey.Name:lower() .. "]  " .. status
            FooterText.TextColor3 = #_footerParts > 0 and T.txtAccent or T.txtNormal
        end
    end)

    function Win:SetFooterParts(parts) _footerParts = parts or {} end

    -- Método helper para cambiar el ToggleKey de forma explícita y segura.
    -- Úsalo en el callback de un Keybind: Win:SetToggleKey(newKey)
    function Win:SetToggleKey(newKey)
        if newKey then
            Win.ToggleKey = newKey
        end
    end

    function Win:CreateTab(tabOpts)
        tabOpts = tabOpts or {}
        local tabName = tabOpts.Name or ("tab"..math.random(1,99))

        local TB = create("TextButton", {
            Name=genRandName(),
            BackgroundTransparency = 1,
            Size = UDim2.new(0,97,0,38), Text = "", AutoButtonColor = false,
        }, TabButtons)
        local TI = create("Frame", {
            Name=genRandName(),
            BackgroundColor3 = T.accent, BorderSizePixel = 0,
            Position = UDim2.new(0,0,0.15,0), Size = UDim2.new(0,2,0.7,0),
            Visible = false,
        }, TB)
        local TL = create("TextLabel", {
            Name=genRandName(),
            AnchorPoint = Vector2.new(0.5,0.5),
            BackgroundTransparency = 1,
            Position = UDim2.new(0.5,3,0.5,0), Size = UDim2.new(1,-10,1,0),
            Font = Enum.Font.Ubuntu, Text = tabName,
            TextSize = 12, TextColor3 = T.txtNormal,
        }, TB)

        local Tab = create("Frame", {
            Name=genRandName(),
            BackgroundTransparency = 1,
            Size = UDim2.new(1,0,1,0), Visible = false,
        }, TabsFrame)
        local TSB = create("Frame", {
            Name=genRandName(),
            BackgroundTransparency = 1,
            Size = UDim2.new(1,0,0,27), ClipsDescendants = false,
        }, Tab)
        create("UIListLayout", {
            FillDirection = Enum.FillDirection.Horizontal,
            HorizontalAlignment = Enum.HorizontalAlignment.Center,
        }, TSB)
        create("Frame", {
            Name=genRandName(),
            BackgroundColor3 = T.border0, BorderSizePixel = 0,
            Position = UDim2.new(0,0,0,27), Size = UDim2.new(1,0,0,1),
        }, Tab)
        local TF = create("Frame", {
            Name=genRandName(),
            BackgroundTransparency = 1,
            Position = UDim2.new(0,0,0,28), Size = UDim2.new(1,0,1,-28),
        }, Tab)

        if _firstTab then
            _firstTab        = false
            _selectedTabBtn  = TB
            TL.TextColor3    = T.txtAccent
            TI.Visible       = true
            Tab.Visible      = true
        end

        TB.MouseButton1Down:Connect(function()
            if _selectedTabBtn == TB then return end
            for _, b in pairs(TabButtons:GetChildren()) do
                if b:IsA("TextButton") then
                    local l = b:FindFirstChildOfClass("TextLabel")
                    local i = b:FindFirstChildOfClass("Frame")
                    if l then tw(l, TweenInfo.new(0.15,Enum.EasingStyle.Quad), {TextColor3=T.txtNormal}) end
                    if i then i.Visible = false end
                end
            end
            for _, t in pairs(TabsFrame:GetChildren()) do t.Visible = false end
            Tab.Visible = true; _selectedTabBtn = TB
            TI.Visible  = true
            tw(TL, TweenInfo.new(0.15,Enum.EasingStyle.Quad), {TextColor3=T.txtAccent})
        end)
        TB.MouseEnter:Connect(function()
            if _selectedTabBtn~=TB then tw(TL, TweenInfo.new(0.12,Enum.EasingStyle.Quad), {TextColor3=T.txtBright}) end
        end)
        TB.MouseLeave:Connect(function()
            if _selectedTabBtn~=TB then tw(TL, TweenInfo.new(0.12,Enum.EasingStyle.Quad), {TextColor3=T.txtNormal}) end
        end)

        local _firstSec       = true
        local _selectedSecBtn = nil

        local TabObj = {}

        function TabObj:CreateSection(secName)
            local SB = create("TextButton", {
                Name=genRandName(),
                BackgroundTransparency = 1,
                Size = UDim2.new(1,0,1,0),
                Font = Enum.Font.Ubuntu, Text = secName,
                TextColor3 = T.txtNormal, TextSize = 13,
                AutoButtonColor = false,
            }, TSB)
            local allSB = {}
            for _, c in pairs(TSB:GetChildren()) do
                if c:IsA("TextButton") then allSB[#allSB+1] = c end
            end
            for _, b in ipairs(allSB) do
                b.Size = UDim2.new(1/#allSB, 0, 1, 0)
            end
            local SD = create("Frame", {
                Name=genRandName(),
                BackgroundColor3 = Color3.fromRGB(255,255,255),
                BorderSizePixel = 0,
                AnchorPoint = Vector2.new(0,1),
                Position = UDim2.new(0,0,1,0), Size = UDim2.new(1,0,0,1),
                Visible = false,
            }, SB)
            create("UIGradient", {
                Color = ColorSequence.new{
                    ColorSequenceKeypoint.new(0,   Color3.fromRGB(20,20,25)),
                    ColorSequenceKeypoint.new(0.5, T.accent),
                    ColorSequenceKeypoint.new(1,   Color3.fromRGB(20,20,25)),
                },
            }, SD)

            local SF = create("Frame", {
                Name=genRandName(),
                BackgroundTransparency = 1,
                Size = UDim2.new(1,0,1,0), Visible = false,
            }, TF)

            local Left  = makeColumn(SF, 6)
            local Right = makeColumn(SF, 298)

            SB.MouseEnter:Connect(function()
                if _selectedSecBtn~=SB then tw(SB, TweenInfo.new(0.12,Enum.EasingStyle.Quad), {TextColor3=T.txtBright}) end
            end)
            SB.MouseLeave:Connect(function()
                if _selectedSecBtn~=SB then tw(SB, TweenInfo.new(0.12,Enum.EasingStyle.Quad), {TextColor3=T.txtNormal}) end
            end)
            SB.MouseButton1Down:Connect(function()
                for _, sb in pairs(TSB:GetChildren()) do
                    if sb:IsA("TextButton") then
                        tw(sb, TweenInfo.new(0.12,Enum.EasingStyle.Quad), {TextColor3=T.txtNormal})
                        local d = sb:FindFirstChild("SD"); if d then d.Visible = false end
                    end
                end
                for _, tf in pairs(TF:GetChildren()) do
                    if tf:IsA("Frame") then tf.Visible = false end
                end
                _selectedSecBtn = SB; SF.Visible = true
                tw(SB, TweenInfo.new(0.12,Enum.EasingStyle.Quad), {TextColor3=T.txtAccent})
                SD.Visible = true
            end)

            if _firstSec then
                _firstSec       = false
                _selectedSecBtn = SB
                SB.TextColor3   = T.txtAccent
                SD.Visible      = true
                SF.Visible      = true
            end

            return Left, Right
        end

        return TabObj
    end

    function Win:SaveConfig(name, data)
        if not data then
            data = {}
            for k, obj in pairs(Library.Flags) do
                pcall(function() data[k] = obj.Value end)
            end
        end
        local ok = cfgSave(name, data)
        if Win.ShowNotifs then
            Library:Notify(ok and ("saved: " .. name) or "save failed", 2.5,
                           ok and "success" or "error")
        end
        return ok
    end

    function Win:LoadConfig(name, applyFn)
        local data = cfgLoad(name)
        if not data then
            if Win.ShowNotifs then Library:Notify("config not found", 2.5, "error") end
            return false
        end
        if applyFn then
            pcall(applyFn, data)
        else
            for k, v in pairs(data) do
                local obj = Library.Flags[k]
                if obj then pcall(function() obj:Silent(v) end) end
            end
        end
        if Win.ShowNotifs then Library:Notify("loaded: " .. name, 2.5, "success") end
        return true
    end

    function Win:DeleteConfig(name)
        cfgDel(name)
        if cfgGetAuto() == name then cfgClearAuto() end
        if Win.ShowNotifs then Library:Notify("deleted: " .. name, 2.5, "warning") end
    end

    function Win:ListConfigs() return cfgList() end

    function Win:SetAutoLoad(name)
        cfgSetAuto(name)
        if Win.ShowNotifs then Library:Notify("autoload: " .. name, 2.5, "info") end
    end

    function Win:ClearAutoLoad()
        cfgClearAuto()
        if Win.ShowNotifs then Library:Notify("autoload cleared", 2.5, "warning") end
    end

    function Win:GetAutoLoad() return cfgGetAuto() end

    function Win:RunAutoLoad(applyFn)
        local al = cfgGetAuto()
        if al then self:LoadConfig(al, applyFn) end
    end

    function Win:Toggle() Main.Visible = not Main.Visible; setCursorVisible(Main.Visible) end
    function Win:SetVisible(v) Main.Visible = v; setCursorVisible(v) end
    function Win:IsVisible() return Main.Visible end

    function Win:Destroy()
        for _, c in ipairs(_conns) do pcall(function() c:Disconnect() end) end
        _conns = {}
        if ScreenGui and ScreenGui.Parent then ScreenGui:Destroy() end
    end

    task.delay(1, function()
        -- Library:Notify ya chequea Library.ShowNotifs internamente,
        -- pero mantenemos el guard de Win.ShowNotifs aquí también
        -- para coherencia con el resto del código de Win.
        if Win.ShowNotifs then
            Library:Notify(Win.Title:lower() .. " v" .. Win.Version .. " ready", 3.5, "info")
            Library:Notify("[" .. Win.ToggleKey.Name:lower() .. "] toggle", 3, "info")
        end
    end)

    return Win
end

function Library:Destroy()
    for _, c in ipairs(_conns) do pcall(function() c:Disconnect() end) end
    _conns = {}
    Library.Flags = {}
    if ScreenGui and ScreenGui.Parent then ScreenGui:Destroy() end
end

-- ═══════════════════════════════════════════════════
--  LIVE PREVIEW HELPERS
-- ═══════════════════════════════════════════════════
function Library:UpdateFOVPreview(radius, visible, filled, color)
    if LivePreviews.FOVCircle then
        if radius  then LivePreviews.FOVCircle.Radius  = radius  end
        if visible ~= nil then LivePreviews.FOVCircle.Visible = visible end
        if filled  ~= nil then LivePreviews.FOVCircle.Filled  = filled  end
        if color   then LivePreviews.FOVCircle.Color   = color   end
    end
end

function Library:UpdateESPPreview(color, visible)
    if LivePreviews.ESPBox then
        if color   then LivePreviews.ESPBox.Color   = color   end
        if visible ~= nil then LivePreviews.ESPBox.Visible = visible end
    end
end

return Library
