local _trailX, _trailY = 0, 0
RunService.RenderStepped:Connect(function()
    local mp = UIS:GetMouseLocation()
    local mx, my = mp.X, mp.Y
    CursorRoot.Position = UDim2.new(0, mx - 10, 0, my - 10)
    _trailX = _trailX + (mx - _trailX) * 0.15
    _trailY = _trailY + (my - _trailY) * 0.15
    TrailRoot.Position = UDim2.new(0, _trailX - 7, 0, _trailY - 7)
end)

local function setCursorVisible(v)
    CursorRoot.Visible = v
    TrailRoot.Visible  = v
    pcall(function()
        UIS.MouseIconEnabled = not v
    end)
end

