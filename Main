local Library     = {}
Library.__index   = Library
Library.Flags     = {}

-- [FIX 1] Flag global para controlar si las notificaciones están activas.
-- CreateWindow lo sincroniza con opts.Notifications.
Library.ShowNotifs = true

-- [FIX 2] Flag global: true mientras un Keybind está esperando input.
-- El hook del ToggleKey lo revisa antes de actuar.
Library._bindingKey = false

local _conns = {}
local function hook(sig, fn)
    local c = sig:Connect(fn)
    _conns[#_conns + 1] = c
    return c
end

-- ═══════════════════════════════════════════════════
--  SCREENGUI (UNDETECTABLE)
-- ═══════════════════════════════════════════════════
local ScreenGui = create("ScreenGui", {
    ResetOnSpawn   = false,
    ZIndexBehavior = Enum.ZIndexBehavior.Global,
    Name           = LEGIT_GUI_NAMES[math.random(1, #LEGIT_GUI_NAMES)],
    IgnoreGuiInset = true,
})

do
    local success = false
    if gethui then
        pcall(function()
            ScreenGui.Parent = gethui()
            success = true
        end)
    end
    if not success then
        pcall(function()
            ScreenGui.Parent = CoreGui
            success = true
        end)
    end
    if not success then
        pcall(function()
            local pg = lp:WaitForChild("PlayerGui", 3)
            if pg then
                ScreenGui.Parent = pg
            end
        end)
    end
end

