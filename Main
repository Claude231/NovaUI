║                                                                  ║
║  API RÁPIDA:                                                     ║
║    local Lib = loadstring(...)()                                 ║
║    local Win = Lib:CreateWindow({ Title, Subtitle, ToggleKey })  ║
║    local Tab = Win:CreateTab({ Name, Icon })                     ║
║    local Sec = Tab:CreateSection("Nombre")                       ║
║    Sec:AddToggle({ Text, Default, Callback, Flag })              ║
║    Sec:AddSlider({ Text, Min, Max, Default, Suffix, Callback })  ║
║    Sec:AddButton({ Text, Description, Style, Callback })         ║
║    Sec:AddDropdown({ Text, List, Default, Callback })            ║
║    Sec:AddTextBox({ Text, Placeholder, Numeric, Callback })      ║
║    Sec:AddKeybind({ Text, Default, Callback })                   ║
║    Sec:AddLabel("Texto")                                         ║
║    Sec:AddSeparator()                                            ║
║    Sec:AddParagraph({ Title, Content })                          ║
║    Lib:Notify("Título", "Desc", 4, "info|success|warning|error") ║
║                                                                  ║
║  Toggle Menú: Tecla "End" (configurable)                        ║
║  Custom Cursor: visible al abrir, oculto al cerrar              ║
╚══════════════════════════════════════════════════════════════════╝
