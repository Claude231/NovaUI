local LivePreviews = {
    FOVCircle = nil,
    ESPBox    = nil,
}

task.spawn(function()
    if Drawing then
        pcall(function()
            local camera     = workspace.CurrentCamera
            local fovCircle  = Drawing.new("Circle")
            fovCircle.Thickness    = 2
            fovCircle.NumSides     = 64
            fovCircle.Radius       = 150
            fovCircle.Filled       = false
            fovCircle.Visible      = false
            fovCircle.ZIndex       = 999
            fovCircle.Color        = Color3.fromRGB(84, 101, 255)
            fovCircle.Transparency = 1
            LivePreviews.FOVCircle = fovCircle
            RunService.RenderStepped:Connect(function()
                if fovCircle and fovCircle.Visible then
                    local cp = camera.ViewportSize / 2
                    fovCircle.Position = Vector2.new(cp.X, cp.Y)
                end
            end)
        end)
    end
end)

task.spawn(function()
    if Drawing then
        pcall(function()
            local espBox       = Drawing.new("Square")
            espBox.Thickness   = 2
            espBox.Size        = Vector2.new(100, 150)
            espBox.Filled      = false
            espBox.Visible     = false
            espBox.ZIndex      = 998
            espBox.Color       = Color3.fromRGB(0, 255, 0)
            espBox.Transparency = 1
            LivePreviews.ESPBox = espBox
            RunService.RenderStepped:Connect(function()
                if espBox and espBox.Visible then
                    local camera  = workspace.CurrentCamera
                    local cp      = camera.ViewportSize / 2
                    espBox.Position = Vector2.new(cp.X - 50, cp.Y - 75)
                end
            end)
        end)
    end
end)

